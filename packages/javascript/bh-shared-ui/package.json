{
    "name": "bh-shared-ui",
    "description": "Shared React Components and Utilities for use in BloodHound and BloodHound Enterprise",
    "main": "dist/index",
    "types": "dist/index",
    "files": [
        "dist",
        "README.md"
    ],
    "type": "module",
    "scripts": {
        "build": "yarn check-types && rollup -c rollup.config.js",
        "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "test": "TZ=America/Los_Angeles vitest",
        "check-types": "tsc --noEmit --pretty",
        "format": "prettier --write \"src/**/*.@(js|jsx|ts|tsx|md|html|css|scss|json)\"",
        "check-format": "prettier  --list-different \"src/**/*.@(js|jsx|ts|tsx|md|html|css|scss|json)\""
    },
    "author": "The BloodHound Enterprise Team (https://bloodhoundenterprise.io/)",
    "license": "MIT",
    "dependencies": {
        "@bloodhoundenterprise/doodleui": "^1.0.0-alpha.37",
        "@date-io/luxon": "^3.2.0",
        "@fortawesome/fontawesome-free": "^6.7.2",
        "@fortawesome/fontawesome-svg-core": "^6.7.2",
        "@fortawesome/free-regular-svg-icons": "^6.7.2",
        "@fortawesome/free-solid-svg-icons": "^6.7.2",
        "@fortawesome/react-fontawesome": "^3.0.2",
        "@mona-health/react-input-mask": "^3.0.3",
        "@neo4j-cypher/editor-support": "^1.0.2",
        "@neo4j-cypher/react-codemirror": "^1.0.4",
        "@reduxjs/toolkit": "^1.9.5",
        "clsx": "^2.1.1",
        "downshift": "^7.0.0",
        "history": "^5.3.0",
        "immutable": "^5.0.0-beta.5",
        "js-client-library": "workspace:*",
        "json-2-csv": "^5.5.9",
        "lodash": "^4.17.21",
        "luxon": "^3.3.0",
        "memoize-one": "^6.0.0",
        "notistack": "^2.0.5",
        "prop-types": "^15.8.1",
        "react-error-boundary": "^3.1.4",
        "react-hook-form": "^7.61.1",
        "react-immutable-proptypes": "^2.2.0",
        "react-query": "^3.39.3",
        "react-router-dom": "^6.30.3",
        "react-window": "^1.8.9",
        "react-window-infinite-loader": "^1.0.9",
        "swagger-ui-react": "^4.18.3",
        "tailwind-merge": "^2.5.4"
    },
    "devDependencies": {
        "@emotion/react": "^11.10.4",
        "@emotion/styled": "^11.10.4",
        "@faker-js/faker": "^7.3.0",
        "@mui/lab": "^5.0.0-alpha.136",
        "@mui/material": "^5.14.0",
        "@mui/styles": "^5.14.0",
        "@rollup/plugin-terser": "^0.4.4",
        "@rollup/plugin-typescript": "^11.1.6",
        "@testing-library/jest-dom": "^5.16.5",
        "@testing-library/react": "^13.3.0",
        "@testing-library/user-event": "^14.4.3",
        "@types/eslint-plugin-jsx-a11y": "^6",
        "@types/lodash": "^4.14.195",
        "@types/luxon": "^3.3.0",
        "@types/prop-types": "^15",
        "@types/react": "^18.2.15",
        "@types/react-window": "^1.8.5",
        "@types/react-window-infinite-loader": "^1.0.6",
        "@types/swagger-ui-react": "^4.18.3",
        "@typescript-eslint/eslint-plugin": "^7.3.0",
        "@typescript-eslint/parser": "^7.3.0",
        "@vitejs/plugin-react": "^4.2.1",
        "@vitest/coverage-v8": "^3.2.4",
        "allure-vitest": "^3.4.3",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.34.1",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-sx-props": "workspace:*",
        "jsdom": "^27.0.0",
        "msw": "^1.3.3",
        "prettier": "^3.2.5",
        "prettier-plugin-organize-imports": "^4.1.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "rollup": "^4.13.2",
        "rollup-plugin-delete": "^2.0.0",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.9.3",
        "vite": "^5.4.19",
        "vitest": "^3.0.0",
        "whatwg-fetch": "^3.6.2"
    },
    "peerDependencies": {
        "@emotion/react": "11.x",
        "@emotion/styled": "11.x",
        "@mui/lab": "5.x",
        "@mui/material": "5.x",
        "@mui/styles": "5.x",
        "react": "18.x",
        "react-dom": "18.x"
    },
    "packageManager": "yarn@3.5.1",
    "installConfig": {
        "hoistingLimits": "workspaces"
    },
    "exports": {
        ".": "./dist/index.js",
        "./FileIngest": "./dist/FileIngest.js",
        "./ApiExplorer": "./dist/ApiExplorer.js",
        "./SSOConfiguration": "./dist/SSOConfiguration.js",
        "./Users": "./dist/Users.js",
        "./UserProfile": "./dist/UserProfile.js",
        "./OpenGraphManagement": "./dist/OpenGraphManagement.js"
    }
}
