{
    "name": "bloodhound-ui",
    "version": "0.0.0",
    "type": "module",
    "private": true,
    "scripts": {
        "debug": "vite --debug",
        "dev": "vite",
        "start": "vite",
        "build": "yarn check-types && vite build",
        "preview": "vite preview",
        "test": "TZ=America/Los_Angeles vitest",
        "check-types": "yarn workspaces foreach -ptRv --include '{bh-shared-ui,js-client-library}' run build && tsc --noEmit --pretty",
        "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
        "format": "prettier --write \"src/**/*.@(js|jsx|ts|tsx|md|html|css|scss|json)\"",
        "check-format": "prettier  --list-different \"src/**/*.@(js|jsx|ts|tsx|md|html|css|scss|json)\""
    },
    "dependencies": {
        "@bloodhoundenterprise/doodleui": "^1.0.0-alpha.37",
        "@dagrejs/dagre": "^1.1.8",
        "@date-io/luxon": "^3.2.0",
        "@emotion/react": "^11.10.4",
        "@emotion/styled": "^11.10.4",
        "@fontsource/roboto": "^4.5.1",
        "@fontsource/roboto-mono": "^4.5.0",
        "@fortawesome/fontawesome-free": "^6.7.2",
        "@fortawesome/fontawesome-svg-core": "^6.7.2",
        "@fortawesome/free-solid-svg-icons": "^6.7.2",
        "@fortawesome/react-fontawesome": "^3.0.2",
        "@mona-health/react-input-mask": "^3.0.3",
        "@mui/lab": "^5.0.0-alpha.136",
        "@mui/material": "^5.14.0",
        "@mui/styles": "^5.14.0",
        "@mui/x-date-pickers": "^5.0.20",
        "@react-sigma/core": "^3.4.1",
        "@reduxjs/toolkit": "^1.8.5",
        "bh-shared-ui": "workspace:*",
        "downshift": "^7.0.0",
        "graphology": "^0.25.1",
        "graphology-layout": "^0.6.1",
        "graphology-layout-forceatlas2": "^0.10.1",
        "history": "^5.3.0",
        "immer": "^10.0.2",
        "js-client-library": "workspace:*",
        "js-cookie": "^3.0.1",
        "js-file-download": "^0.4.12",
        "json-2-csv": "^5.5.9",
        "lodash": "^4.17.21",
        "luxon": "^3.3.0",
        "memoize-one": "^6.0.0",
        "notistack": "^2.0.5",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-error-boundary": "^3.1.4",
        "react-helmet": "^6.1.0",
        "react-hook-form": "^7.61.1",
        "react-query": "^3.39.3",
        "react-redux": "^8.1.1",
        "react-router-dom": "^6.30.3",
        "react-window": "^1.8.9",
        "redux-saga": "^1.1.3",
        "sass": "^1.62.1",
        "sigma": "^2.4.0"
    },
    "devDependencies": {
        "@faker-js/faker": "^7.3.0",
        "@testing-library/jest-dom": "^5.16.5",
        "@testing-library/react": "^13.3.0",
        "@testing-library/user-event": "^14.4.3",
        "@types/eslint-plugin-jsx-a11y": "^6",
        "@types/js-cookie": "^3.0.3",
        "@types/lodash": "^4.14.195",
        "@types/luxon": "^3.3.0",
        "@types/node": "^22.9.0",
        "@types/react": "^18.0.28",
        "@types/react-dom": "^18.0.11",
        "@types/react-helmet": "^6.1.11",
        "@types/react-window": "^1.8.5",
        "@typescript-eslint/eslint-plugin": "^7.3.0",
        "@typescript-eslint/parser": "^7.3.0",
        "@vitejs/plugin-react": "^4.2.1",
        "@vitest/coverage-v8": "^3.2.4",
        "allure-vitest": "^3.4.3",
        "autoprefixer": "^10.4.20",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.34.1",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.6",
        "eslint-plugin-sx-props": "workspace:*",
        "graphology-types": "^0.24.7",
        "jest-webgl-canvas-mock": "^2.5.0",
        "jsdom": "^27.0.0",
        "lint-staged": "^10.5.4",
        "msw": "^1.3.3",
        "postcss": "^8.5.1",
        "prettier": "^3.2.5",
        "prettier-plugin-organize-imports": "^4.1.0",
        "redux-devtools-extension": "^2.13.9",
        "redux-saga-test-plan": "^4.0.3",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.9.3",
        "vite": "^5.4.19",
        "vite-plugin-glsl": "^1.3.0",
        "vitest": "^3.0.0",
        "vitest-canvas-mock": "^0.3.3",
        "whatwg-fetch": "^3.6.2"
    },
    "packageManager": "yarn@3.5.0",
    "msw": {
        "workerDirectory": "public"
    },
    "installConfig": {
        "hoistingLimits": "workspaces"
    }
}
